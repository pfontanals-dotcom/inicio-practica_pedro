// Dado un listado de números reales del cual no se conoce la cantidad, almacenar los números en un vector en el orden de entrada. Informar la cantidad de números y el contenido del vector indicando la posición ocupada por cada número. Considerar una estructura de datos de tamaño físico máximo de 1000 posiciones.
#include <stdio.h>
#define MAX 1000
typedef double Tvec[MAX];

int main() {
   Tvec v;
   int i,p;
   int contador=0;
   double numero;
   printf("ingrese un numero difernte de 0:\n");
   scanf("%lf", &numero);
   while (numero!=0 && (contador<MAX)){
       for(i=0;i<numero;i++){
            v[i]=numero;
           contador++;
           printf("ingrese otro numero (0 para terminar):\n");
           scanf("%lf", &numero);
       }
       
   }
   printf("cantidad de numeros ingresados: %d\n",contador);
   for( i = 0; i < contador; i++) {
        printf("Posicion %d: %.2f\n", i , v[i]);
    }

   
    return 0;
}

// Un número entero positivo se dice perfecto si es igual a la suma de todos sus divisores excepto él mismo. Ejemplo: los números 6, 28 y 496 son perfectos.  Escribir una función booleana que permita discernir si un número (único parámetro) es perfecto. ejemplos
//(6 = 1+2+3)
//(28 = 1+2+4+7+14)
//(496 = 1+2+4+8+16+31+62+124 +248)



#include <stdio.h>

int num_perfecto(int n){
    
    int i;
    int aux=0;
    
    if (n>5){
     for(i=1;i<n;i++){
         if (n%i==0){
             aux+=i;
         }
     }
    }
    return aux==n;
}

int main() {
    int p=28;
    
    if( num_perfecto(p)==1){
        printf("el numero %i es perfecto", p);
    }
    else{
         printf("el numero %i no es perfecto", p);
    }
   
    return 0;
}
